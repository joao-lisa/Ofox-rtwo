name: OrangeFox Build

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    timeout-minutes: 240
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
      
      - name: Setup environment
        run: |
          sudo apt-get update
          sudo apt-get install -y git-core gnupg flex bison build-essential \
            libelf-dev libudev-dev pkg-config ccache zlib1g-dev libssl-dev \
            python3 python3-doc python3-pip ncurses-dev xz-utils \
            libncurses-dev
      
      - name: Create directories
        run: |
          mkdir -p ~/OFOX
          cd ~/OFOX
      
      - name: Clone OrangeFox recovery
        run: |
          cd ~/OFOX
          git clone https://github.com/OrangeFox/recovery.git -b fox_12.1 . --depth 1
      
      - name: Clone device tree
        run: |
          cd ~/OFOX
          mkdir -p device/motorola
          git clone https://github.com/TheSithLordDarthImperivious/android_device_motorola_rtwo device/motorola_rtwo
      
      - name: Create fox_rtwo.mk
        run: |
          cd ~/OFOX/device/motorola_rtwo
          cat > fox_rtwo.mk << 'EOF'
          PRODUCT_RELEASE_NAME := rtwo
          DEVICE_PATH := device/motorola_rtwo
          $(call inherit-product-if-exists, $(DEVICE_PATH)/fox_rtwo.mk)
          PRODUCT_NAME := ofox_rtwo
          PRODUCT_DEVICE := rtwo
          EOF
      
      - name: Setup build environment
        run: |
          cd ~/OFOX
          source build/envsetup.sh
      
      - name: Lunch device
        run: |
          cd ~/OFOX
          source build/envsetup.sh
          lunch ofox_rtwo-eng
      
      - name: Build recovery
        run: |
          cd ~/OFOX
          source build/envsetup.sh
          lunch ofox_rtwo-eng
          mka recoveryimage
      
      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: recovery-img-rtwo
          path: ~/OFOX/out/target/product/rtwo/recovery.img
          retention-days: 5
